# OpenRouter — https://openrouter.ai/docs/quickstart
OPENROUTER_API_KEY=sk-or-v1-...

# Optional OpenRouter attribution headers
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_SITE_NAME=quickstart-openrouter

# LangChain / LangGraph model id (openrouter: prefix)
# If you get "guardrail restrictions and data policy", fix:
# https://openrouter.ai/settings/privacy then: uv run python main.py --check
# Cheapest Anthropic that works with strict ZDR (~$1/M in, ~$5/M out)
OPENROUTER_MODEL=openrouter:anthropic/claude-haiku-4.5

# Raw slug for examples/openrouter_direct.py only
OPENROUTER_RAW_MODEL=anthropic/claude-haiku-4.5

# LangSmith (optional)
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=...
